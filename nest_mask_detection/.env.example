# OAuth 2.0 Credentials (from Google Cloud Console)
GOOGLE_CLIENT_ID=2ENterclientid
GOOGLE_CLIENT_SECRET=ENTERCLIENTSECRET
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/callback

# Google Cloud Project
GOOGLE_CLOUD_PROJECT_ID=your-project-id-here
NEST_DEVICE_ID=your-nest-device-id-here
GOOGLE_HOME_API_KEY=your-api-key-here

# Pub/Sub Configuration
PUBSUB_TOPIC=projects/your-project-id/topics/nest-events
PUBSUB_SUBSCRIPTION=projects/your-project-id/subscriptions/nest-events-sub

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
DEBUG=false

# Database Configuration
DATABASE_URL=sqlite:///./predictions.db
# For PostgreSQL:
# DATABASE_URL=postgresql://user:password@localhost:5432/mask_detection

# Model Configuration
MODEL_NAME=yolov8n
CONFIDENCE_THRESHOLD=0.5
IOU_THRESHOLD=0.45
IMG_SIZE=640
DEVICE=cpu
